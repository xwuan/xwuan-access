{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ],
  "redirects": [
    { "source": "/a", "destination": "/admin", "permanent": false },
    { "source": "/i", "destination": "/install", "permanent": false }
  ]
}
